# ============================================================
# fried-plantains — environment configuration template
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# Security
SECRET_KEY=                        # Min 32 chars, random — generate with: openssl rand -hex 32
ADMIN_USERNAME=                    # Initial admin username
ADMIN_PASSWORD_HASH=               # bcrypt hash — generate with: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))"

# Token config
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Query engine
QUERY_TIMEOUT_SECONDS=30
MAX_UPLOAD_SIZE_MB=500

# Storage
STORAGE_ROOT=./storage             # Absolute or relative path — must exist before starting

# Server
CORS_ORIGIN=http://localhost:5173  # Frontend URL — no trailing slash
LOG_LEVEL=INFO
